<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="Adw" version="1.0"/>

  <menu id="app_menu_model">
    <section>
      <item>
        <attribute name="label">Preferences</attribute>
        <attribute name="action">win.preferences</attribute>
      </item>
      <item>
        <attribute name="label">About Waytator</attribute>
        <attribute name="action">win.about</attribute>
      </item>
    </section>
  </menu>

  <menu id="save_menu_model">
    <section>
      <item>
        <attribute name="label">Save</attribute>
        <attribute name="action">win.save</attribute>
      </item>
      <item>
        <attribute name="label">Save as copy</attribute>
        <attribute name="action">win.save-copy</attribute>
      </item>
    </section>
  </menu>

  <menu id="file_menu_model">
    <section>
      <item>
        <attribute name="label">Open file</attribute>
        <attribute name="action">win.open-current-file</attribute>
      </item>
      <item>
        <attribute name="label">Open containing folder</attribute>
        <attribute name="action">win.open-containing-folder</attribute>
      </item>
    </section>
  </menu>

  <template class="WaytatorWindow" parent="AdwApplicationWindow">
    <property name="default-width">1120</property>
    <property name="default-height">760</property>
    <property name="title">Waytator</property>

    <property name="content">
      <object class="AdwBottomSheet" id="ocr_panel_bottom_sheet">
        <property name="can-open">False</property>
        <property name="modal">False</property>
        <property name="show-drag-handle">True</property>

        <child>
          <object class="GtkOverlay">
            <property name="child">
              <object class="GtkStack" id="canvas_stack">
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>
                <property name="transition-type">crossfade</property>

                <child>
                  <object class="GtkBox" id="empty_page">
                    <property name="orientation">vertical</property>
                    <property name="valign">center</property>
                    <property name="halign">center</property>
                    <property name="spacing">14</property>
                    <style>
                      <class name="canvas-empty"/>
                    </style>

                    <child>
                      <object class="GtkImage">
                        <property name="icon-name">image-x-generic-symbolic</property>
                        <property name="pixel-size">40</property>
                        <style>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">Open an image to begin</property>
                        <style>
                          <class name="title-3"/>
                        </style>
                      </object>
                    </child>

                    <child>
                      <object class="GtkButton">
                        <property name="label">Open image</property>
                        <property name="action-name">win.open</property>
                        <style>
                          <class name="suggested-action"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="GtkScrolledWindow" id="canvas_scroller">
                    <property name="hexpand">True</property>
                    <property name="vexpand">True</property>
                    <property name="has-frame">False</property>
                    <property name="kinetic-scrolling">False</property>
                    <property name="overlay-scrolling">True</property>
                    <property name="hscrollbar-policy">automatic</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <style>
                      <class name="canvas-scroller"/>
                    </style>

                    <child>
                      <object class="GtkOverlay" id="canvas_surface">
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="canvas-surface"/>
                        </style>

                        <property name="child">
                          <object class="GtkBox" id="canvas_background">
                            <property name="hexpand">True</property>
                            <property name="vexpand">True</property>
                          </object>
                        </property>

                        <child type="overlay">
                          <object class="GtkPicture" id="picture">
                            <property name="can-shrink">True</property>
                            <property name="keep-aspect-ratio">True</property>
                            <property name="focusable">True</property>
                            <layout>
                              <property name="measure">False</property>
                            </layout>
                          </object>
                        </child>

                        <child type="overlay">
                          <object class="GtkDrawingArea" id="drawing_area">
                            <property name="hexpand">True</property>
                            <property name="vexpand">True</property>
                            <property name="can-focus">True</property>
                            <property name="focusable">True</property>
                            <layout>
                              <property name="measure">False</property>
                            </layout>
                          </object>
                        </child>

                        <child type="overlay">
                          <object class="GtkFixed" id="ocr_overlay">
                            <property name="hexpand">True</property>
                            <property name="vexpand">True</property>
                            <property name="visible">False</property>
                            <property name="can-focus">False</property>
                            <property name="focusable">False</property>
                            <layout>
                              <property name="measure">False</property>
                            </layout>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>

            <child type="overlay">
              <object class="GtkWindowHandle">
                <property name="halign">fill</property>
                <property name="valign">start</property>

                <property name="child">
                  <object class="GtkCenterBox">
                    <property name="hexpand">True</property>
                    <property name="margin-start">16</property>
                    <property name="margin-end">16</property>
                    <property name="margin-top">16</property>

                    <property name="start-widget">
                      <object class="GtkBox" id="start_actions">
                        <property name="valign">center</property>
                        <property name="spacing">10</property>

                        <child>
                          <object class="GtkBox" id="start_window_controls_pill">
                            <property name="visible">False</property>
                            <style>
                              <class name="overlay-pill"/>
                              <class name="app-chrome-group"/>
                            </style>

                            <child>
                              <object class="GtkWindowControls" id="start_window_controls">
                                <property name="side">start</property>
                                <style>
                                  <class name="overlay-window-controls"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox" id="open_actions">
                            <property name="valign">center</property>
                            <style>
                              <class name="overlay-pill"/>
                              <class name="open-group"/>
                            </style>
                            <child>
                              <object class="GtkButton">
                                <property name="action-name">win.open</property>
                                <property name="label">Open</property>
                                <style>
                                  <class name="overlay-button"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox" id="history_actions">
                            <property name="spacing">4</property>
                            <style>
                              <class name="overlay-pill"/>
                              <class name="overlay-action-group"/>
                            </style>

                            <child>
                              <object class="GtkButton" id="undo_button">
                                <property name="tooltip-text">Undo</property>
                                <property name="sensitive">False</property>
                                <property name="icon-name">edit-undo-symbolic</property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkButton" id="redo_button">
                                <property name="tooltip-text">Redo</property>
                                <property name="sensitive">False</property>
                                <property name="icon-name">edit-redo-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>

                    <property name="center-widget">
                      <object class="GtkBox" id="tool_group">
                        <property name="valign">center</property>
                        <property name="spacing">4</property>
                        <property name="sensitive">False</property>
                        <style>
                          <class name="overlay-pill"/>
                          <class name="tool-group"/>
                        </style>

                        <child>
                          <object class="GtkToggleButton" id="pan_tool_button">
                            <property name="group">brush_tool_button</property>
                            <property name="tooltip-text">Pan</property>
                            <property name="icon-name">waytator-pan-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkToggleButton" id="crop_tool_button">
                            <property name="group">brush_tool_button</property>
                            <property name="tooltip-text">Crop</property>
                            <property name="icon-name">waytator-crop-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkToggleButton" id="brush_tool_button">
                            <property name="tooltip-text">Brush</property>
                            <property name="active">True</property>
                            <property name="icon-name">waytator-pencil-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkToggleButton" id="highlighter_tool_button">
                            <property name="group">brush_tool_button</property>
                            <property name="tooltip-text">Highlighter</property>
                            <property name="icon-name">waytator-highlight-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkToggleButton" id="eraser_tool_button">
                            <property name="group">brush_tool_button</property>
                            <property name="tooltip-text">Eraser</property>
                            <property name="icon-name">waytator-eraser-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkMenuButton" id="shapes_tool_button">
                            <property name="tooltip-text">Shapes</property>
                            <property name="icon-name">waytator-shapes-symbolic</property>
                            <property name="popover">
                              <object class="GtkPopover" id="shapes_popover">
                                <child>
                                  <object class="GtkGrid">
                                    <property name="column-spacing">6</property>
                                    <property name="row-spacing">6</property>
                                    <property name="margin-start">8</property>
                                    <property name="margin-end">8</property>
                                    <property name="margin-top">8</property>
                                    <property name="margin-bottom">8</property>
                                    <style>
                                      <class name="shape-grid"/>
                                    </style>

                                    <child>
                                      <object class="GtkToggleButton" id="rectangle_tool_button">
                                        <property name="group">brush_tool_button</property>
                                        <property name="tooltip-text">Rectangle</property>
                                        <property name="width-request">40</property>
                                        <property name="height-request">40</property>
                                        <style>
                                          <class name="shape-choice"/>
                                          <class name="flat"/>
                                        </style>
                                        <property name="child">
                                          <object class="GtkImage">
                                            <property name="icon-name">waytator-rectangle-symbolic</property>
                                          </object>
                                        </property>
                                        <layout>
                                          <property name="column">0</property>
                                          <property name="row">0</property>
                                        </layout>
                                      </object>
                                    </child>

                                    <child>
                                      <object class="GtkToggleButton" id="circle_tool_button">
                                        <property name="group">brush_tool_button</property>
                                        <property name="tooltip-text">Circle</property>
                                        <property name="width-request">40</property>
                                        <property name="height-request">40</property>
                                        <style>
                                          <class name="shape-choice"/>
                                          <class name="flat"/>
                                        </style>
                                        <property name="child">
                                          <object class="GtkImage">
                                            <property name="icon-name">waytator-circle-symbolic</property>
                                          </object>
                                        </property>
                                        <layout>
                                          <property name="column">1</property>
                                          <property name="row">0</property>
                                        </layout>
                                      </object>
                                    </child>

                                    <child>
                                      <object class="GtkToggleButton" id="line_tool_button">
                                        <property name="group">brush_tool_button</property>
                                        <property name="tooltip-text">Line</property>
                                        <property name="width-request">40</property>
                                        <property name="height-request">40</property>
                                        <style>
                                          <class name="shape-choice"/>
                                          <class name="flat"/>
                                        </style>
                                        <property name="child">
                                          <object class="GtkImage">
                                            <property name="icon-name">waytator-line-symbolic</property>
                                          </object>
                                        </property>
                                        <layout>
                                          <property name="column">0</property>
                                          <property name="row">1</property>
                                        </layout>
                                      </object>
                                    </child>

                                    <child>
                                      <object class="GtkToggleButton" id="arrow_tool_button">
                                        <property name="group">brush_tool_button</property>
                                        <property name="tooltip-text">Arrow</property>
                                        <property name="width-request">40</property>
                                        <property name="height-request">40</property>
                                        <style>
                                          <class name="shape-choice"/>
                                          <class name="flat"/>
                                        </style>
                                        <property name="child">
                                          <object class="GtkImage">
                                            <property name="icon-name">waytator-arrow-symbolic</property>
                                          </object>
                                        </property>
                                        <layout>
                                          <property name="column">1</property>
                                          <property name="row">1</property>
                                        </layout>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkToggleButton" id="ocr_tool_button">
                            <property name="group">brush_tool_button</property>
                            <property name="tooltip-text">Recognize text</property>
                            <property name="icon-name">waytator-scanner-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkToggleButton" id="text_tool_button">
                            <property name="group">brush_tool_button</property>
                            <property name="tooltip-text">Text</property>
                            <property name="icon-name">waytator-text-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkToggleButton" id="blur_tool_button">
                            <property name="group">brush_tool_button</property>
                            <property name="tooltip-text">Blur</property>
                            <property name="icon-name">waytator-blur-symbolic</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkSeparator">
                            <property name="orientation">vertical</property>
                            <property name="margin-start">4</property>
                            <property name="margin-end">4</property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="rotate_counter_clockwise_button">
                            <property name="tooltip-text">Rotate counter clockwise</property>
                            <property name="icon-name">waytator-rotate-counter-clockwise-symbolic</property>
                            <property name="action-name">win.rotate-counter-clockwise</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="flip_horizontal_button">
                            <property name="tooltip-text">Flip horizontal</property>
                            <property name="icon-name">object-flip-horizontal-symbolic</property>
                            <property name="action-name">win.flip-horizontal</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="flip_vertical_button">
                            <property name="tooltip-text">Flip vertical</property>
                            <property name="icon-name">object-flip-vertical-symbolic</property>
                            <property name="action-name">win.flip-vertical</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </property>

                    <property name="end-widget">
                      <object class="GtkBox">
                        <property name="valign">center</property>
                        <property name="spacing">10</property>

                        <child>
                          <object class="GtkBox" id="document_actions">
                            <property name="spacing">4</property>
                            <style>
                              <class name="overlay-pill"/>
                              <class name="overlay-action-group"/>
                            </style>

                            <child>
                          <object class="GtkMenuButton" id="save_button">
                            <property name="tooltip-text">Save</property>
                            <property name="sensitive">False</property>
                            <property name="direction">down</property>
                            <property name="menu-model">save_menu_model</property>
                            <property name="child">
                              <object class="GtkStack" id="save_icon_stack">
                                <property name="transition-type">crossfade</property>
                                    <property name="transition-duration">160</property>

                                    <child>
                                      <object class="GtkImage" id="save_default_icon">
                                        <property name="icon-name">document-save-symbolic</property>
                                      </object>
                                    </child>

                                    <child>
                                      <object class="GtkImage" id="save_working_icon">
                                        <property name="icon-name">view-refresh-symbolic</property>
                                        <style>
                                          <class name="spinning-icon"/>
                                        </style>
                                      </object>
                                    </child>

                                    <child>
                                      <object class="GtkImage" id="save_success_icon">
                                        <property name="icon-name">object-select-symbolic</property>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                          </object>
                        </child>

                            <child>
                              <object class="GtkButton" id="copy_button">
                                <property name="tooltip-text">Copy</property>
                                <property name="sensitive">False</property>
                                <property name="child">
                                  <object class="GtkStack" id="copy_icon_stack">
                                    <property name="transition-type">crossfade</property>
                                    <property name="transition-duration">160</property>

                                    <child>
                                      <object class="GtkImage" id="copy_default_icon">
                                        <property name="icon-name">edit-copy-symbolic</property>
                                      </object>
                                    </child>

                                    <child>
                                      <object class="GtkImage" id="copy_success_icon">
                                        <property name="icon-name">object-select-symbolic</property>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="GtkBox" id="app_chrome_group">
                            <property name="spacing">4</property>
                            <style>
                              <class name="overlay-pill"/>
                              <class name="app-chrome-group"/>
                            </style>

                            <child>
                              <object class="GtkMenuButton" id="app_menu_button">
                                <property name="always-show-arrow">False</property>
                                <property name="tooltip-text">More</property>
                                <property name="menu-model">app_menu_model</property>
                                <property name="child">
                                  <object class="GtkImage">
                                    <property name="icon-name">view-more-symbolic</property>
                                  </object>
                                </property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>

                            <child>
                              <object class="GtkWindowControls" id="end_window_controls">
                                <property name="side">end</property>
                                <style>
                                  <class name="overlay-window-controls"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </child>

            <child type="overlay">
              <object class="GtkCenterBox">
                <property name="halign">fill</property>
                <property name="valign">end</property>
                <property name="margin-start">16</property>
                <property name="margin-end">16</property>
                <property name="margin-bottom">16</property>

                <property name="start-widget">
                  <object class="GtkBox" id="file_group">
                    <property name="valign">fill</property>
                    <style>
                      <class name="overlay-pill"/>
                      <class name="overlay-readout"/>
                    </style>

                    <child>
                      <object class="GtkMenuButton" id="file_button">
                        <property name="direction">up</property>
                        <property name="menu-model">file_menu_model</property>
                        <property name="always-show-arrow">False</property>
                        <property name="sensitive">False</property>
                        <property name="child">
                          <object class="GtkLabel" id="file_label">
                            <property name="xalign">0</property>
                            <property name="ellipsize">end</property>
                            <property name="max-width-chars">30</property>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </property>

                <property name="center-widget">
                  <object class="GtkBox">
                    <property name="spacing">10</property>
                    <property name="valign">fill</property>
                    <child>
                      <object class="GtkBox" id="settings_group">
                        <property name="spacing">4</property>
                        <property name="sensitive">False</property>
                        <property name="valign">fill</property>
                        <style>
                          <class name="overlay-pill"/>
                          <class name="settings-group"/>
                        </style>
                        <child>
                          <object class="GtkColorDialogButton" id="color_button">
                            <property name="valign">center</property>
                            <property name="tooltip-text">Stroke color</property>
                            <property name="dialog">
                              <object class="GtkColorDialog"/>
                            </property>
                            <property name="rgba">rgba(245, 51, 71, 1.0)</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkColorDialogButton" id="fill_color_button">
                            <property name="valign">center</property>
                            <property name="tooltip-text">Fill color</property>
                            <property name="dialog">
                              <object class="GtkColorDialog">
                                <property name="with-alpha">True</property>
                              </object>
                            </property>
                            <property name="rgba">rgba(245, 51, 71, 0.0)</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkDropDown" id="blur_type_dropdown">
                            <property name="valign">center</property>
                            <property name="model">
                              <object class="GtkStringList">
                                <items>
                                  <item>Blur</item>
                                  <item>Pixelate</item>
                                </items>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScale" id="width_scale">
                            <property name="orientation">horizontal</property>
                            <property name="width-request">150</property>
                            <property name="valign">center</property>
                            <property name="draw-value">False</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">1.0</property>
                                <property name="upper">100.0</property>
                                <property name="value">6.0</property>
                                <property name="step-increment">1.0</property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkMenuButton" id="size_button">
                            <property name="valign">center</property>
                            <property name="tooltip-text">Set size precisely</property>
                            <property name="always-show-arrow">False</property>
                            <style>
                              <class name="flat"/>
                              <class name="size-button"/>
                            </style>
                            <property name="child">
                              <object class="GtkLabel" id="size_button_label">
                                <property name="label">6 px</property>
                                <property name="width-chars">4</property>
                                <property name="xalign">0.5</property>
                              </object>
                            </property>
                            <property name="popover">
                              <object class="GtkPopover">
                                <child>
                                  <object class="GtkBox">
                                    <property name="margin-start">10</property>
                                    <property name="margin-end">10</property>
                                    <property name="margin-top">10</property>
                                    <property name="margin-bottom">10</property>
                                    <child>
                                      <object class="GtkSpinButton" id="precise_size_spin">
                                        <property name="valign">center</property>
                                        <property name="adjustment">
                                          <object class="GtkAdjustment">
                                            <property name="lower">1.0</property>
                                            <property name="upper">100.0</property>
                                            <property name="value">6.0</property>
                                            <property name="step-increment">1.0</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="text_size_spin">
                            <property name="valign">center</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">8.0</property>
                                <property name="upper">200.0</property>
                                <property name="value">24.0</property>
                                <property name="step-increment">1.0</property>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox" id="ocr_panel_toggle_container">
                        <property name="visible">False</property>
                        <property name="valign">center</property>
                        <style>
                          <class name="overlay-pill"/>
                          <class name="overlay-readout"/>
                        </style>

                        <child>
                          <object class="GtkToggleButton" id="ocr_panel_toggle_button">
                            <property name="tooltip-text">Show OCR text panel</property>
                            <property name="label">OCR</property>
                            <style>
                              <class name="overlay-button"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>

                <property name="end-widget">
                  <object class="GtkBox">
                    <property name="spacing">10</property>
                    <property name="valign">fill</property>

                    <child>
                      <object class="GtkBox" id="zoom_group">
                        <property name="spacing">8</property>
                        <property name="sensitive">False</property>
                        <property name="valign">fill</property>
                        <style>
                          <class name="overlay-pill"/>
                          <class name="zoom-group"/>
                        </style>

                        <child>
                          <object class="GtkButton">
                            <property name="action-name">win.zoom-out</property>
                            <property name="tooltip-text">Zoom out</property>
                            <property name="icon-name">zoom-out-symbolic</property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkLabel" id="zoom_label">
                            <property name="label">100%</property>
                            <style>
                              <class name="zoom-label"/>
                            </style>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton">
                            <property name="action-name">win.zoom-in</property>
                            <property name="tooltip-text">Zoom in</property>
                            <property name="icon-name">zoom-in-symbolic</property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="fit_zoom_button">
                            <property name="action-name">win.zoom-fit</property>
                            <property name="tooltip-text">Fit image to window</property>
                            <property name="label">Fit</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>

        <child type="sheet">
          <object class="GtkBox" id="ocr_panel">
            <property name="margin-start">16</property>
            <property name="margin-end">16</property>
            <property name="margin-bottom">16</property>
            <property name="orientation">vertical</property>
            <property name="spacing">10</property>
            <style>
              <class name="ocr-panel"/>
            </style>

            <child>
              <object class="GtkCenterBox">
                <property name="start-widget">
                  <object class="GtkStackSwitcher" id="ocr_panel_tabs">
                    <property name="halign">start</property>
                    <property name="stack">ocr_panel_stack</property>
                    <style>
                      <class name="ocr-tabs"/>
                    </style>
                  </object>
                </property>

                <property name="end-widget">
                  <object class="GtkButton" id="ocr_panel_close_button">
                    <property name="icon-name">pan-down-symbolic</property>
                    <property name="tooltip-text">Hide OCR panel</property>
                    <style>
                      <class name="flat"/>
                      <class name="ocr-panel-close"/>
                    </style>
                  </object>
                </property>
              </object>
            </child>

            <child>
              <object class="GtkStack" id="ocr_panel_stack">
                <property name="hhomogeneous">False</property>
                <property name="vhomogeneous">False</property>
                <property name="transition-type">crossfade</property>

                <child>
                  <object class="GtkScrolledWindow" id="ocr_selected_page">
                    <property name="max-content-height">128</property>
                    <property name="hscrollbar-policy">never</property>
                    <property name="propagate-natural-height">True</property>

                    <child>
                      <object class="GtkTextView" id="ocr_selected_text_view">
                        <property name="editable">False</property>
                        <property name="cursor-visible">False</property>
                        <property name="wrap-mode">word-char</property>
                        <property name="top-margin">10</property>
                        <property name="bottom-margin">10</property>
                        <property name="left-margin">12</property>
                        <property name="right-margin">12</property>
                        <style>
                          <class name="ocr-text-view"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="GtkScrolledWindow" id="ocr_all_page">
                    <property name="max-content-height">196</property>
                    <property name="hscrollbar-policy">never</property>
                    <property name="propagate-natural-height">True</property>

                    <child>
                      <object class="GtkTextView" id="ocr_all_text_view">
                        <property name="editable">False</property>
                        <property name="cursor-visible">False</property>
                        <property name="wrap-mode">word-char</property>
                        <property name="top-margin">10</property>
                        <property name="bottom-margin">10</property>
                        <property name="left-margin">12</property>
                        <property name="right-margin">12</property>
                        <style>
                          <class name="ocr-text-view"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
